---
import Icon from './Icon.astro';
import LangSwitcher from './LangSwitcher.astro';
import { useTranslations } from '../i18n';
import type { Locale } from '../data/villa';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const links = [
  { href: '#gallery', label: t('nav.gallery') },
  { href: '#villa', label: t('nav.villa') },
  { href: '#area', label: t('nav.area') },
  { href: '#rates', label: t('nav.rates') },
  { href: '#booking', label: t('nav.book') },
  { href: '#reviews', label: t('nav.reviews') },
];
---

<header class="header" data-header>
  <div class="header__inner container">
    <a href="#top" class="brand" aria-label="Can Miró, home">
      <span class="brand__mark">Can</span>
      <span class="brand__name">Miró</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <ul class="nav__list">
        {links.map((l) => (
          <li><a href={l.href} class="nav__link">{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="header__actions">
      <LangSwitcher locale={locale} />
      <a href="#enquire" class="btn header__cta">{t('nav.enquire')}</a>
      <button type="button" class="header__toggle" data-menu-toggle aria-expanded="false" aria-label={t('nav.menu')}>
        <Icon name="menu" size={26} />
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="drawer" data-drawer hidden>
    <ul class="drawer__list">
      {links.map((l) => (
        <li><a href={l.href} class="drawer__link" data-drawer-link>{l.label}</a></li>
      ))}
      <li><a href="#enquire" class="btn drawer__cta" data-drawer-link>{t('nav.enquire')}</a></li>
    </ul>
  </div>
</header>

<style>
  .header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: var(--header-h);
    transition: background-color 0.3s var(--ease), box-shadow 0.3s var(--ease),
      border-color 0.3s var(--ease);
    border-bottom: 1px solid transparent;
  }
  .header[data-scrolled] {
    background: rgba(250, 246, 240, 0.86);
    backdrop-filter: saturate(140%) blur(12px);
    border-bottom-color: var(--border);
    box-shadow: var(--shadow-sm);
  }
  .header__inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.01em;
    color: var(--heading);
  }
  .brand__mark { font-weight: 400; }
  .brand__name { color: var(--accent); font-style: italic; }

  .nav__list {
    display: flex;
    gap: 1.9rem;
  }
  .nav__link {
    position: relative;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    padding: 0.25rem 0;
    transition: color 0.2s var(--ease);
  }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    background: var(--accent);
    transition: width 0.25s var(--ease);
  }
  .nav__link:hover { color: var(--heading); }
  .nav__link:hover::after { width: 100%; }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .header__cta {
    padding: 0.6rem 1.25rem;
    font-size: 0.95rem;
  }
  .header__toggle {
    display: none;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    color: var(--heading);
    cursor: pointer;
    padding: 0.25rem;
  }

  .drawer {
    position: fixed;
    inset: var(--header-h) 0 auto 0;
    background: var(--c-white);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow);
    padding: 1rem var(--gutter) 1.75rem;
  }
  .drawer__list { display: grid; gap: 0.25rem; }
  .drawer__link {
    display: block;
    padding: 0.9rem 0.25rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--heading);
    border-bottom: 1px solid var(--border);
  }
  .drawer__cta {
    margin-top: 1rem;
    width: 100%;
    padding: 0.9rem;
    font-size: 1.05rem;
  }

  /* Reveal-from-top animation for the drawer */
  .drawer[hidden] { display: none; }

  @media (max-width: 900px) {
    .nav { display: none; }
    .header__cta { display: none; }
    .header__toggle { display: inline-flex; }
  }
  @media (min-width: 901px) {
    .drawer { display: none !important; }
  }
</style>

<script>
  // Sticky header shadow on scroll.
  const header = document.querySelector('[data-header]');
  const onScroll = () => {
    if (window.scrollY > 24) header?.setAttribute('data-scrolled', '');
    else header?.removeAttribute('data-scrolled');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile drawer.
  const toggle = document.querySelector('[data-menu-toggle]');
  const drawer = document.querySelector('[data-drawer]');
  const setOpen = (open: boolean) => {
    if (!drawer || !toggle) return;
    drawer.toggleAttribute('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
  };
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!open);
  });
  document.querySelectorAll('[data-drawer-link]').forEach((a) =>
    a.addEventListener('click', () => setOpen(false))
  );
</script>
