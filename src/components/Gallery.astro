---
import { Image, getImage } from 'astro:assets';
import Icon from './Icon.astro';
import { useTranslations } from '../i18n';
import type { Locale } from '../data/villa';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Load every placeholder in the gallery folder.
const files = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/gallery/*.{jpg,jpeg,png,webp}',
  { eager: true }
);

// Map filename token -> caption key. Order matters: more specific tokens first.
const captionByToken: Record<string, string> = {
  'pool-terrace': 'poolTerrace',
  'pool-night': 'poolNight',
  'aerial-pool': 'aerial',
  dining: 'alfresco',
  lounge: 'outdoorLounge',
  daybed: 'daybed',
  villa: 'villa',
  gardens: 'gardens',
  setting: 'setting',
  overview: 'overview',
};

function captionKey(path: string): string {
  const base = path.split('/').pop() ?? '';
  for (const token of Object.keys(captionByToken)) {
    if (base.includes(token)) return captionByToken[token];
  }
  return 'villa';
}

const sorted = Object.entries(files).sort(([a], [b]) => a.localeCompare(b));

// Prepare optimized thumbnails + full-size sources (for PhotoSwipe).
const items = await Promise.all(
  sorted.map(async ([path, mod], i) => {
    const src = mod.default;
    const full = await getImage({ src, width: 1600, format: 'webp' });
    const caption = t(`gallery.captions.${captionKey(path)}`);
    return {
      src,
      fullSrc: full.src,
      fullW: 1600,
      fullH: Math.round((1600 * src.height) / src.width),
      caption,
      // Emphasis pattern for a varied editorial grid.
      big: i === 0 || i === 3 || i === 6,
      index: i,
    };
  })
);
---

<section class="section gallery" id="gallery">
  <div class="container">
    <div class="gallery__head reveal">
      <div>
        <p class="eyebrow">{t('gallery.eyebrow')}</p>
        <h2 class="section-title">{t('gallery.title')}</h2>
        <p class="lead">{t('gallery.subtitle')}</p>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="gallery__grid reveal" id="gallery-grid">
      {items.map((item) => (
        <a
          class:list={['gallery__item', { 'gallery__item--big': item.big }]}
          href={item.fullSrc}
          data-pswp-width={item.fullW}
          data-pswp-height={item.fullH}
          target="_blank"
          rel="noopener"
          aria-label={item.caption}
        >
          <Image
            src={item.src}
            alt={item.caption}
            widths={[400, 700, 1000]}
            sizes="(max-width: 700px) 100vw, (max-width: 1100px) 50vw, 33vw"
            loading="lazy"
            class="gallery__img"
          />
          <span class="gallery__caption">
            <span>{item.caption}</span>
            <Icon name="arrow" size={18} />
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery__head {
    max-width: var(--container-narrow);
    margin-bottom: 2.5rem;
  }
  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.9rem;
    grid-auto-flow: dense;
  }
  .gallery__item {
    position: relative;
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--bg-raised);
    box-shadow: var(--shadow-sm);
  }
  .gallery__item--big {
    grid-column: span 2;
    grid-row: span 2;
    aspect-ratio: auto;
  }
  .gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .gallery__item:hover .gallery__img {
    transform: scale(1.05);
  }
  .gallery__caption {
    position: absolute;
    inset: auto 0 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 1.5rem 1.1rem 0.9rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: #fff;
    background: linear-gradient(180deg, transparent, rgba(36, 31, 25, 0.6));
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
  }
  .gallery__caption :global(svg) {
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
  }
  .gallery__item:hover .gallery__caption,
  .gallery__item:focus-visible .gallery__caption {
    opacity: 1;
    transform: none;
  }
  .gallery__item:hover .gallery__caption :global(svg) {
    opacity: 0.9;
    transform: none;
  }

  @media (max-width: 760px) {
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.6rem;
    }
    .gallery__item--big { grid-column: span 2; grid-row: span 1; aspect-ratio: 16 / 10; }
    .gallery__caption { opacity: 1; transform: none; padding-top: 2rem; }
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery-grid',
    children: 'a.gallery__item',
    pswpModule: () => import('photoswipe'),
    bgOpacity: 0.92,
    showHideAnimationType: 'zoom',
  });

  // Show the caption inside the lightbox.
  lightbox.on('uiRegister', () => {
    lightbox.pswp?.ui?.registerElement({
      name: 'custom-caption',
      order: 9,
      isButton: false,
      appendTo: 'root',
      html: '',
      onInit: (el) => {
        el.className = 'pswp__custom-caption';
        lightbox.pswp?.on('change', () => {
          const curr = lightbox.pswp?.currSlide?.data.element as HTMLElement | undefined;
          const label = curr?.getAttribute('aria-label') ?? '';
          el.innerHTML = label;
        });
      },
    });
  });

  lightbox.init();
</script>

<style is:global>
  .pswp__custom-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 16px;
    text-align: center;
    color: rgba(255, 255, 255, 0.92);
    font-family: var(--font-display, Georgia, serif);
    font-style: italic;
    font-size: 1.05rem;
    pointer-events: none;
  }
</style>
