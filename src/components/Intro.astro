---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import introImage from '../assets/images/intro.jpg';
import { useTranslations } from '../i18n';
import type { Locale } from '../data/villa';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const features = [
  { icon: 'pool', key: 'pool' },
  { icon: 'sun', key: 'seating' },
  { icon: 'kitchen', key: 'kitchens' },
  { icon: 'beach', key: 'beach' },
];
---

<section class="section intro" id="intro">
  <div class="container intro__grid">
    <div class="intro__text reveal">
      <p class="eyebrow">{t('intro.eyebrow')}</p>
      <h2 class="section-title">{t('intro.title')}</h2>
      <p class="intro__body">{t('intro.body')}</p>

      <ul class="intro__features">
        {features.map((f) => (
          <li>
            <span class="intro__ficon"><Icon name={f.icon} size={22} /></span>
            {t(`intro.features.${f.key}`)}
          </li>
        ))}
      </ul>
    </div>

    <div class="intro__media reveal">
      <Image
        src={introImage}
        alt=""
        widths={[500, 800, 1200]}
        sizes="(max-width: 900px) 100vw, 45vw"
        loading="lazy"
        class="intro__img"
      />
      <div class="intro__badge">
        <span class="intro__badge-num">4×</span>
        <span class="intro__badge-label">{t('intro.features.seating')}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .intro__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .intro__body {
    font-size: var(--fs-lead);
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 2rem;
  }
  .intro__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem 1.5rem;
  }
  .intro__features li {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-weight: 500;
    color: var(--heading);
  }
  .intro__ficon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--bg-raised);
    color: var(--accent);
    flex-shrink: 0;
  }

  .intro__media { position: relative; }
  .intro__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }
  .intro__badge {
    position: absolute;
    left: -1.25rem;
    bottom: 2rem;
    background: var(--c-white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    max-width: 150px;
  }
  .intro__badge-num {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--accent);
    line-height: 1;
  }
  .intro__badge-label {
    font-size: var(--fs-small);
    color: var(--text-soft);
    margin-top: 0.25rem;
  }

  @media (max-width: 900px) {
    .intro__grid { grid-template-columns: 1fr; }
    .intro__media { order: -1; }
    .intro__img { aspect-ratio: 16 / 10; }
    .intro__badge { left: auto; right: 1rem; }
  }
  @media (max-width: 460px) {
    .intro__features { grid-template-columns: 1fr; }
  }
</style>
