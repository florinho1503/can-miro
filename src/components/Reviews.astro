---
import Icon from './Icon.astro';
import { useTranslations } from '../i18n';
import { villa, type Locale } from '../data/villa';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const summary = t('reviews.ratingSummary')
  .replace('{avg}', String(villa.ratingAverage))
  .replace('{count}', String(villa.ratingCount));
---

<section class="section reviews" id="reviews">
  <div class="container">
    <div class="reviews__head reveal">
      <p class="eyebrow">{t('reviews.eyebrow')}</p>
      <h2 class="section-title">{t('reviews.title')}</h2>
      <p class="reviews__rating">
        <span class="reviews__stars" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => <Icon name="star" size={22} />)}
        </span>
        <span class="reviews__summary">{summary}</span>
      </p>
    </div>

    <div class="reviews__grid">
      {villa.reviews.map((review) => (
        <figure class="review reveal">
          <div class="review__stars" aria-label={`${review.rating} / 5`}>
            {Array.from({ length: review.rating }).map(() => <Icon name="star" size={16} />)}
          </div>
          <blockquote class="review__quote">{t(`reviews.items.${review.quoteId}`)}</blockquote>
          <figcaption class="review__by">
            <span class="review__name">{review.name}</span>
            <span class="review__meta">{review.origin} · {review.date}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews {
    background: var(--bg-raised);
  }
  .reviews__head {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 3rem;
  }
  .reviews__rating {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin: 0;
  }
  .reviews__stars { display: inline-flex; color: var(--c-terracotta); }
  .reviews__summary { color: var(--text-soft); font-weight: 500; }

  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .review {
    background: var(--c-white);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    margin: 0;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .review__stars { display: inline-flex; color: var(--c-terracotta); }
  .review__quote {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.2rem;
    line-height: 1.5;
    color: var(--heading);
    font-style: italic;
  }
  .review__by {
    margin-top: auto;
    display: grid;
    gap: 0.15rem;
  }
  .review__name { font-weight: 700; color: var(--heading); }
  .review__meta { font-size: var(--fs-small); color: var(--text-soft); }

  @media (max-width: 860px) {
    .reviews__grid { grid-template-columns: 1fr; max-width: 560px; margin-inline: auto; }
  }
</style>
