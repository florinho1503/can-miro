  }
  .booking .b-day.is-empty { border: 0; background: transparent; cursor: default; }
  .booking .b-num { font-size: 0.95rem; font-weight: 600; line-height: 1; }
  .booking .b-price { font-size: 0.68rem; color: var(--text-soft); line-height: 1; white-space: nowrap; }
  .booking .b-day.is-avail:hover { border-color: var(--c-sea); background: var(--c-sand-50); transform: translateY(-1px); }
  .booking .b-day.is-booked {
    background: var(--bg-raised);
    color: var(--c-stone-400);
    cursor: not-allowed;
    text-decoration: line-through;
    text-decoration-color: var(--c-stone-400);
  }
  .booking .b-day.is-past { opacity: 0.32; cursor: default; }
  .booking .b-day.is-range { background: rgba(47, 109, 120, 0.12); border-color: transparent; }
  .booking .b-day.is-arrival,
  .booking .b-day.is-departure { background: var(--c-sea); border-color: var(--c-sea); color: #fff; }
  .booking .b-day.is-arrival .b-price,
  .booking .b-day.is-departure .b-price { color: rgba(255, 255, 255, 0.85); }

  .booking .booking__grid--week .b-week {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
  }
  .booking .b-wday {
