    padding: 1rem 0.3rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--c-white);
    font: inherit;
    color: var(--heading);
    cursor: pointer;
    transition: border-color 0.15s var(--ease), background-color 0.15s var(--ease);
  }
  .booking .b-wday-name { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-soft); }
  .booking .b-wday .b-num { font-size: 1.5rem; font-family: var(--font-display); }
  .booking .b-wday.is-avail:hover { border-color: var(--c-sea); background: var(--c-sand-50); }
  .booking .b-wday.is-booked { background: var(--bg-raised); color: var(--c-stone-400); cursor: not-allowed; }
  .booking .b-wday.is-past { opacity: 0.32; cursor: default; }
  .booking .b-wday.is-range { background: rgba(47, 109, 120, 0.12); }
  .booking .b-wday.is-arrival, .booking .b-wday.is-departure { background: var(--c-sea); border-color: var(--c-sea); color: #fff; }
  .booking .b-price--muted { color: var(--c-stone-400); }

  .booking .booking__grid--year .b-year {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 0.9rem;
  }
  .booking .b-mcard {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--c-white);
    font: inherit;
    text-align: left;
    color: var(--heading);
    cursor: pointer;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
