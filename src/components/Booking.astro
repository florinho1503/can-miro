---
import Icon from './Icon.astro';
import { useTranslations } from '../i18n';
import type { Locale } from '../data/villa';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Strings the client script needs, handed over as inline JSON.
const bi = {
  from: t('booking.from'),
  perNight: t('booking.perNight'),
  night: t('booking.night'),
  nights: t('booking.nights'),
  nightsAvailable: t('booking.nightsAvailable'),
  selectArrival: t('booking.selectArrival'),
  selectDeparture: t('booking.selectDeparture'),
  total: t('booking.total'),
  weekOf: t('booking.weekOf'),
  booked: t('booking.booked'),
};
---

<section class="section booking" id="booking">
  <div class="container">
    <div class="booking__head reveal">
      <p class="eyebrow">{t('booking.eyebrow')}</p>
      <h2 class="section-title">{t('booking.title')}</h2>
      <p class="lead">{t('booking.subtitle')}</p>
    </div>

    <div class="booking__card reveal" data-booking data-locale={locale}>
      <script type="application/json" data-booking-i18n is:inline set:html={JSON.stringify(bi)}
      ></script>

      <div class="booking__toolbar">
        <div class="booking__views" role="tablist" aria-label="Calendar view">
          <button type="button" class="booking__view" role="tab" data-view="year">{t('booking.year')}</button>
          <button type="button" class="booking__view" role="tab" data-view="month" aria-selected="true">{t('booking.month')}</button>
          <button type="button" class="booking__view" role="tab" data-view="week">{t('booking.week')}</button>
        </div>
        <div class="booking__nav">
          <button type="button" class="booking__navbtn" data-nav="prev" aria-label={t('booking.prevMonth')}>
            <Icon name="chevron" size={20} class="is-prev" />
          </button>
          <span class="booking__title" data-title></span>
          <button type="button" class="booking__navbtn" data-nav="next" aria-label={t('booking.nextMonth')}>
            <Icon name="chevron" size={20} class="is-next" />
          </button>
        </div>
      </div>

      <div class="booking__grid booking__grid--month" data-grid></div>

      <div class="booking__legend">
        <span><i class="booking__dot booking__dot--avail"></i>{t('booking.available')}</span>
        <span><i class="booking__dot booking__dot--booked"></i>{t('booking.booked')}</span>
        <span><i class="booking__dot booking__dot--sel"></i>{t('booking.selected')}</span>
      </div>

      <div class="booking__summary">
        <p class="booking__summary-text" data-summary-text role="status" aria-live="polite"></p>
        <div class="booking__summary-actions">
          <button type="button" class="btn btn--ghost booking__clear" data-clear hidden>{t('booking.change')}</button>
          <a class="btn booking__request" data-request href="#enquire" hidden>{t('booking.request')}</a>
        </div>
      </div>

      <p class="booking__note">{t('booking.note')}</p>
    </div>
  </div>
</section>

<style>
  .booking__head {
    max-width: var(--container-narrow);
    margin-bottom: 2.5rem;
  }
  .booking__card {
    background: var(--c-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: clamp(1.25rem, 3vw, 2.25rem);
  }

  .booking__toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .booking__views {
    display: inline-flex;
    background: var(--bg-raised);
    border-radius: var(--radius-pill);
    padding: 4px;
    gap: 2px;
  }
  .booking__view {
    border: 0;
    background: transparent;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-soft);
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .booking__view[aria-selected='true'] {
    background: var(--c-white);
    color: var(--heading);
    box-shadow: var(--shadow-sm);
  }

  .booking__nav {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .booking__title {
    min-width: 11ch;
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--heading);
    text-transform: capitalize;
  }
  .booking__navbtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--border);
    border-radius: 50%;
    background: var(--c-white);
    color: var(--heading);
    cursor: pointer;
    transition: border-color 0.2s var(--ease), background-color 0.2s var(--ease);
  }
  .booking__navbtn:hover { border-color: var(--c-stone-400); background: var(--bg-raised); }
  .booking__navbtn :global(.is-prev) { transform: rotate(90deg); }
  .booking__navbtn :global(.is-next) { transform: rotate(-90deg); }

  /* Month grid */
  .booking__grid--month .b-weekdays,
  .booking__grid--month .b-month {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
  }
  .b-weekdays {
    margin-bottom: 6px;
  }
  .b-weekdays span {
    text-align: center;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-soft);
    padding-bottom: 4px;
  }
  .b-day {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--c-white);
    font: inherit;
    color: var(--heading);
    cursor: pointer;
    padding: 2px;
    transition: border-color 0.15s var(--ease), background-color 0.15s var(--ease),
      transform 0.15s var(--ease);
  }
  .b-day.is-empty { border: 0; background: transparent; cursor: default; }
  .b-num { font-size: 0.95rem; font-weight: 600; line-height: 1; }
  .b-price { font-size: 0.68rem; color: var(--text-soft); line-height: 1; white-space: nowrap; }

  .b-day.is-avail:hover { border-color: var(--c-sea); background: var(--c-sand-50); transform: translateY(-1px); }
  .b-day.is-booked {
    background: var(--bg-raised);
    color: var(--c-stone-400);
    cursor: not-allowed;
    text-decoration: line-through;
    text-decoration-color: var(--c-stone-400);
  }
  .b-day.is-past { opacity: 0.32; cursor: default; }
  .b-day.is-range { background: rgba(47, 109, 120, 0.12); border-color: transparent; }
  .b-day.is-arrival,
  .b-day.is-departure {
    background: var(--c-sea);
    border-color: var(--c-sea);
    color: #fff;
  }
  .b-day.is-arrival .b-price,
  .b-day.is-departure .b-price { color: rgba(255, 255, 255, 0.85); }

  /* Week grid */
  .booking__grid--week .b-week {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
  }
  .b-wday {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 1rem 0.3rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--c-white);
    font: inherit;
    color: var(--heading);
    cursor: pointer;
    transition: border-color 0.15s var(--ease), background-color 0.15s var(--ease);
  }
  .b-wday-name { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-soft); }
  .b-wday .b-num { font-size: 1.5rem; font-family: var(--font-display); }
  .b-wday.is-avail:hover { border-color: var(--c-sea); background: var(--c-sand-50); }
  .b-wday.is-booked { background: var(--bg-raised); color: var(--c-stone-400); cursor: not-allowed; }
  .b-wday.is-past { opacity: 0.32; cursor: default; }
  .b-wday.is-range { background: rgba(47, 109, 120, 0.12); }
  .b-wday.is-arrival, .b-wday.is-departure { background: var(--c-sea); border-color: var(--c-sea); color: #fff; }
  .b-price--muted { color: var(--c-stone-400); }

  /* Year grid */
  .booking__grid--year .b-year {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 0.9rem;
  }
  .b-mcard {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--c-white);
    font: inherit;
    text-align: left;
    color: var(--heading);
    cursor: pointer;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .b-mcard:hover { border-color: var(--c-sea); transform: translateY(-3px); box-shadow: var(--shadow); }
  .b-mcard.is-past { opacity: 0.4; cursor: default; }
  .b-mname { font-family: var(--font-display); font-size: 1.35rem; text-transform: capitalize; }
  .b-mfrom { font-size: 0.9rem; color: var(--text-soft); }
  .b-mfrom strong { color: var(--accent); font-size: 1.05rem; }
  .b-mavail { font-size: 0.8rem; color: var(--c-olive); font-weight: 600; }

  /* Legend + summary */
  .booking__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1.5rem;
    font-size: var(--fs-small);
    color: var(--text-soft);
  }
  .booking__legend span { display: inline-flex; align-items: center; gap: 0.45rem; }
  .booking__dot { width: 14px; height: 14px; border-radius: 4px; display: inline-block; }
  .booking__dot--avail { background: var(--c-white); border: 1px solid var(--border); }
  .booking__dot--booked { background: var(--bg-raised); border: 1px solid var(--c-stone-400); }
  .booking__dot--sel { background: var(--c-sea); }

  .booking__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .booking__summary-text { margin: 0; color: var(--text); font-size: 1.05rem; }
  .booking__summary-text strong { color: var(--heading); }
  .booking__summary-actions { display: inline-flex; gap: 0.75rem; }
  .booking__note { margin: 1.25rem 0 0; font-size: var(--fs-small); color: var(--text-soft); }

  @media (max-width: 560px) {
    .booking__toolbar { justify-content: center; }
    .booking__summary { justify-content: center; text-align: center; }
    .booking__summary-actions { width: 100%; }
    .booking__request { flex: 1; }
  }
</style>

<!--
  The calendar cells are injected by the client script at runtime, so they do
  not receive Astro's scoped-style attribute. Their styles must be global.
  Everything here is namespaced under .booking so nothing leaks out.
-->
<style is:global>
