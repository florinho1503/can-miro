  @media (max-width: 560px) {
    .booking .b-price { font-size: 0.6rem; }
    .booking .b-wday .b-num { font-size: 1.15rem; }
  }
</style>

<script>
  import { priceForDate, isAvailable, fromPriceForMonth, daysInMonth, blockedRanges } from '../data/availability';

  const root = document.querySelector('[data-booking]');
  if (root) {
    const locale = root.getAttribute('data-locale') || 'en';
    const t = JSON.parse(root.querySelector('[data-booking-i18n]').textContent || '{}');
    const grid = root.querySelector('[data-grid]');
    const titleEl = root.querySelector('[data-title]');
    const summaryText = root.querySelector('[data-summary-text]');
    const clearBtn = root.querySelector('[data-clear]');
    const requestBtn = root.querySelector('[data-request]');
    const viewBtns = Array.from(root.querySelectorAll('[data-view]'));
    const navBtns = Array.from(root.querySelectorAll('[data-nav]'));

    const money = new Intl.NumberFormat(locale, {
      style: 'currency',
      currency: 'EUR',
      maximumFractionDigits: 0,
    });

    const now = new Date();
    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    const monthStart = (d) => new Date(d.getFullYear(), d.getMonth(), 1);

    const state = { view: 'month', focus: monthStart(today), arrival: null, departure: null };

    const iso = (d) =>
      `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    const parseISO = (s) => {
      const [y, m, dd] = s.split('-').map(Number);
      return new Date(y, m - 1, dd);
    };
    const addDays = (d, n) => new Date(d.getFullYear(), d.getMonth(), d.getDate() + n);
    const startOfWeek = (d) => addDays(d, -((d.getDay() + 6) % 7));
    const nightsBetween = (a, b) => Math.round((b - a) / 86400000);

    const weekdayNames = Array.from({ length: 7 }, (_, i) =>
      new Date(2024, 0, 1 + i).toLocaleDateString(locale, { weekday: 'short' })
    );

    const rangeAvailable = (a, b) => {
      for (let d = new Date(a); d < b; d = addDays(d, 1)) if (!isAvailable(d, today)) return false;
      return true;
    };
    const totalPrice = (a, b) => {
      let s = 0;
      for (let d = new Date(a); d < b; d = addDays(d, 1)) s += priceForDate(d);
      return s;
    };
    const dayFlags = (d) => ({
      avail: isAvailable(d, today),
      past: d < today,
      isArr: state.arrival && +d === +state.arrival,
      isDep: state.departure && +d === +state.departure,
      inRange: state.arrival && state.departure && d > state.arrival && d < state.departure,
    });
    const dayClasses = (d, base) => {
      const f = dayFlags(d);
      const c = [base];
      if (f.past) c.push('is-past');
      else if (!f.avail) c.push('is-booked');
      else c.push('is-avail');
      if (f.isArr) c.push('is-arrival');
      if (f.isDep) c.push('is-departure');
      if (f.inRange) c.push('is-range');
      return { cls: c.join(' '), selectable: f.avail && !f.past, avail: f.avail, past: f.past };
    };

    function renderMonth() {
      const y = state.focus.getFullYear();
      const m = state.focus.getMonth();
      titleEl.textContent = state.focus.toLocaleDateString(locale, { month: 'long', year: 'numeric' });
      let html = '<div class="b-weekdays">' + weekdayNames.map((w) => `<span>${w}</span>`).join('') + '</div>';
      html += '<div class="b-month">';
      const offset = (new Date(y, m, 1).getDay() + 6) % 7;
      for (let i = 0; i < offset; i++) html += '<div class="b-day is-empty"></div>';
      const dim = daysInMonth(y, m);
      for (let day = 1; day <= dim; day++) {
        const d = new Date(y, m, day);
        const { cls, selectable, avail, past } = dayClasses(d, 'b-day');
        const tag = selectable ? 'button' : 'div';
        const attrs = selectable ? `type="button" data-date="${iso(d)}"` : 'aria-disabled="true"';
        const price = avail && !past ? `<span class="b-price">${money.format(priceForDate(d))}</span>` : '';
        html += `<${tag} class="${cls}" ${attrs}><span class="b-num">${day}</span>${price}</${tag}>`;
      }
      html += '</div>';
      grid.className = 'booking__grid booking__grid--month';
      grid.innerHTML = html;
    }

    function renderWeek() {
      const ws = startOfWeek(state.focus);
      titleEl.textContent = `${t.weekOf} ${ws.toLocaleDateString(locale, { day: 'numeric', month: 'short' })}`;
      let html = '<div class="b-week">';
      for (let i = 0; i < 7; i++) {
        const d = addDays(ws, i);
        const { cls, selectable, avail, past } = dayClasses(d, 'b-wday');
        const tag = selectable ? 'button' : 'div';
        const attrs = selectable ? `type="button" data-date="${iso(d)}"` : 'aria-disabled="true"';
        const price =
          avail && !past
            ? `<span class="b-price">${money.format(priceForDate(d))}</span>`
            : `<span class="b-price b-price--muted">${past ? '' : t.booked}</span>`;
        html += `<${tag} class="${cls}" ${attrs}><span class="b-wday-name">${weekdayNames[i]}</span><span class="b-num">${d.getDate()}</span>${price}</${tag}>`;
      }
      html += '</div>';
      grid.className = 'booking__grid booking__grid--week';
      grid.innerHTML = html;
    }

    function renderYear() {
      const y = state.focus.getFullYear();
      titleEl.textContent = String(y);
      let html = '<div class="b-year">';
      for (let m = 0; m < 12; m++) {
        const isPast = y < today.getFullYear() || (y === today.getFullYear() && m < today.getMonth());
        const from = fromPriceForMonth(y, m);
        let avail = 0;
        const dim = daysInMonth(y, m);
        for (let day = 1; day <= dim; day++) if (isAvailable(new Date(y, m, day), today)) avail++;
        const name = new Date(y, m, 1).toLocaleDateString(locale, { month: 'long' });
        const tag = isPast ? 'div' : 'button';
        const attrs = isPast ? 'aria-disabled="true"' : `type="button" data-month="${m}"`;
        html += `<${tag} class="b-mcard${isPast ? ' is-past' : ''}" ${attrs}>
            <span class="b-mname">${name}</span>
            <span class="b-mfrom">${t.from} <strong>${money.format(from)}</strong> ${t.perNight}</span>
            <span class="b-mavail">${avail} ${t.nightsAvailable}</span>
          </${tag}>`;
      }
      html += '</div>';
      grid.className = 'booking__grid booking__grid--year';
      grid.innerHTML = html;
    }

    function updateSummary() {
      if (state.arrival && state.departure) {
        const n = nightsBetween(state.arrival, state.departure);
        const a = state.arrival.toLocaleDateString(locale, { day: 'numeric', month: 'short' });
        const b = state.departure.toLocaleDateString(locale, { day: 'numeric', month: 'short', year: 'numeric' });
        summaryText.innerHTML = `<strong>${a} → ${b}</strong> · ${n} ${n === 1 ? t.night : t.nights} · ${t.total} <strong>${money.format(totalPrice(state.arrival, state.departure))}</strong>`;
        clearBtn.hidden = false;
        requestBtn.hidden = false;
      } else if (state.arrival) {
        const a = state.arrival.toLocaleDateString(locale, { day: 'numeric', month: 'short' });
        summaryText.innerHTML = `<strong>${a}</strong> · ${t.selectDeparture}`;
        clearBtn.hidden = false;
        requestBtn.hidden = true;
      } else {
        summaryText.textContent = t.selectArrival;
        clearBtn.hidden = true;
        requestBtn.hidden = true;
      }
    }

    function render() {
      viewBtns.forEach((b) => b.setAttribute('aria-selected', String(b.dataset.view === state.view)));
      if (state.view === 'year') renderYear();
      else if (state.view === 'week') renderWeek();
      else renderMonth();
      updateSummary();
    }

    function pick(dstr) {
      const d = parseISO(dstr);
      if (!state.arrival || (state.arrival && state.departure)) {
        state.arrival = d;
        state.departure = null;
      } else if (+d <= +state.arrival) {
        state.arrival = d;
        state.departure = null;
      } else if (rangeAvailable(state.arrival, d)) {
        state.departure = d;
      } else {
        state.arrival = d;
        state.departure = null;
      }
      render();
    }

    grid.addEventListener('click', (e) => {
      const day = e.target.closest('[data-date]');
      if (day) return pick(day.dataset.date);
      const mo = e.target.closest('[data-month]');
      if (mo) {
        state.view = 'month';
        state.focus = new Date(state.focus.getFullYear(), Number(mo.dataset.month), 1);
        render();
      }
    });

    viewBtns.forEach((b) =>
      b.addEventListener('click', () => {
        state.view = b.dataset.view;
        if (state.view === 'week' && state.focus < today) state.focus = new Date(today);
        if (state.view === 'month' && state.focus < monthStart(today)) state.focus = monthStart(today);
        render();
      })
    );

    navBtns.forEach((b) =>
      b.addEventListener('click', () => {
        const dir = b.dataset.nav === 'next' ? 1 : -1;
        if (state.view === 'year') {
          const ny = state.focus.getFullYear() + dir;
          if (ny >= today.getFullYear()) state.focus = new Date(ny, 0, 1);
        } else if (state.view === 'week') {
          const nf = addDays(startOfWeek(state.focus), dir * 7);
          if (dir > 0 || nf >= startOfWeek(today)) state.focus = nf;
        } else {
          const nm = new Date(state.focus.getFullYear(), state.focus.getMonth() + dir, 1);
          if (nm >= monthStart(today)) state.focus = nm;
        }
        render();
      })
    );

    clearBtn.addEventListener('click', () => {
      state.arrival = null;
      state.departure = null;
      render();
    });

    requestBtn.addEventListener('click', () => {
      if (state.arrival && state.departure) {
        const ai = document.getElementById('f-arrival');
        const di = document.getElementById('f-departure');
        if (ai) ai.value = iso(state.arrival);
        if (di) di.value = iso(state.departure);
      }
      // href="#enquire" handles the scroll
    });

    render();

    // Pull real availability (confirmed bookings) from Supabase, then re-render.
    // No backend configured -> everything stays available. Only PII-free date
    // ranges are returned by the `availability()` RPC.
    (async () => {
      const url = import.meta.env.PUBLIC_SUPABASE_URL;
      const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
      if (!url || !key) return;
      try {
        const res = await fetch(`${url}/rest/v1/rpc/availability`, {
          method: 'POST',
          headers: { apikey: key, Authorization: `Bearer ${key}`, 'Content-Type': 'application/json' },
          body: '{}',
        });
        if (!res.ok) return;
        const rows = await res.json();
        if (Array.isArray(rows)) {
          for (const r of rows) {
            if (r.arrival && r.departure) blockedRanges.push({ start: r.arrival, end: r.departure });
          }
          render();
        }
      } catch {
        /* offline / not configured: leave calendar fully available */
      }
    })();
  }
</script>
