  .booking .booking__grid--month .b-month {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
  }
  .booking .b-weekdays { margin-bottom: 6px; }
  .booking .b-weekdays span {
    text-align: center;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
