---
import Icon from './Icon.astro';
import { useTranslations } from '../i18n';
import { villa, type Locale } from '../data/villa';
import { config, whatsappLink } from '../config';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const year = 2026;
const links = [
  { href: '#gallery', label: t('nav.gallery') },
  { href: '#villa', label: t('nav.villa') },
  { href: '#area', label: t('nav.area') },
  { href: '#rates', label: t('nav.rates') },
  { href: '#booking', label: t('nav.book') },
  { href: '#reviews', label: t('nav.reviews') },
  { href: '#enquire', label: t('nav.enquire') },
];
---

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <span class="footer__logo">Can <em>Miró</em></span>
      <p class="footer__tagline">{t('footer.tagline')}</p>
      <p class="footer__reg">
        {t('footer.registration')}: <strong>{villa.registrationNumber}</strong>
      </p>
    </div>

    <nav class="footer__col" aria-label={t('footer.quickLinks')}>
      <h3 class="footer__h">{t('footer.quickLinks')}</h3>
      <ul>
        {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer__col">
      <h3 class="footer__h">{t('footer.contact')}</h3>
      <ul>
        <li>
          <a href={`mailto:${config.email}`}>
            <Icon name="mail" size={18} /> {config.email}
          </a>
        </li>
        <li>
          <a href={whatsappLink(t('whatsapp.prefill'))} target="_blank" rel="noopener">
            <Icon name="whatsapp" size={18} /> WhatsApp
          </a>
        </li>
        <li>
          <span class="footer__loc">
            <Icon name="pin" size={18} /> {villa.location.urbanisation}, {villa.location.town}
          </span>
        </li>
      </ul>
    </div>
  </div>

  <div class="container footer__bar">
    <p>© {year} Can Miró. {t('footer.rights')}</p>
    <a href="#top" class="footer__top">
      {t('footer.backToTop')} <Icon name="arrowUp" size={16} />
    </a>
  </div>
</footer>

<style>
  .footer {
    background: var(--c-ink-900);
    color: rgba(255, 255, 255, 0.72);
    padding-top: clamp(3rem, 7vw, 5rem);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: #fff;
  }
  .footer__logo em { color: var(--c-terracotta); font-style: italic; }
  .footer__tagline {
    margin: 0.75rem 0 1rem;
    max-width: 34ch;
    line-height: 1.6;
  }
  .footer__reg {
    font-size: var(--fs-small);
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }
  .footer__reg strong { color: rgba(255, 255, 255, 0.8); font-weight: 600; }

  .footer__h {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 1.1rem;
  }
  .footer__col ul { display: grid; gap: 0.7rem; }
  .footer__col a,
  .footer__loc {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: rgba(255, 255, 255, 0.78);
    transition: color 0.2s var(--ease);
  }
  .footer__col a:hover { color: #fff; }
  .footer__col :global(svg) { color: var(--c-terracotta); flex-shrink: 0; }

  .footer__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: var(--fs-small);
  }
  .footer__top {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.2s var(--ease);
  }
  .footer__top:hover { color: #fff; }

  @media (max-width: 820px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .footer__grid { grid-template-columns: 1fr; gap: 2rem; }
    .footer__bar { flex-direction: column; align-items: flex-start; }
  }
</style>
