# Copy this file to `.env`. The WhatsApp number and email below are also set as
# defaults in src/config.ts, so the site already shows them without a .env.
# The one thing you must add to actually RECEIVE enquiries by email is the
# Web3Forms access key (free at https://web3forms.com).

# Web3Forms access key. Sign up at web3forms.com with florisbokx@gmail.com as
# the destination, paste the key here. Empty = form falls back to opening the
# guest's own mail app (less reliable).
PUBLIC_WEB3FORMS_KEY=

# Contact details surfaced across the site.
PUBLIC_WHATSAPP_NUMBER=31651475439
PUBLIC_CONTACT_EMAIL=florisbokx@gmail.com

# Supabase (booking backend + /admin portal). Public by design (RLS protects
# data). From Supabase: Project Settings -> API. Empty = calendar shows all
# available and /admin shows "not configured".
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
